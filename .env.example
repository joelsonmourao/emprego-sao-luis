# Banco deste projeto no PostgreSQL compartilhado do servidor (banco: emprego_sao_luis)
DATABASE_URL=""
# Em dev local pode ser igual ao DATABASE_URL. Em produção com pooler, use URL direta aqui.
DATABASE_URL_DIRECT=""

# URL canônica de produção
SITE_URL="https://empregossaoluis.com.br"
NEXT_PUBLIC_SITE_URL="https://empregossaoluis.com.br"
NEXT_PUBLIC_SITE_NAME="Emprego São Luís"

# Autenticação do painel /admin
AUTH_SECRET="troque-esta-chave-por-uma-segura-com-pelo-menos-32-caracteres"
ADMIN_LOGIN_USER="seu-email-admin@empregossaoluis.com.br"
# Gere com: node -e "const b=require('bcryptjs'); console.log(b.hashSync('SUA_SENHA_FORTE',10))"
ADMIN_SECRET_KEY="defina-uma-senha-admin-forte"

# AdSense — configure somente após aprovação
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""

# Opcional
APP_TIME_ZONE="America/Sao_Paulo"
CRON_SECRET="defina-um-token-secreto-para-cron"

# Resetar conteúdo padrão no seed
# RESET_SITE_CONTENT=1
