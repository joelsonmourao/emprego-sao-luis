DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jovem_aprendiz_vagas?schema=jovem_aprendiz_vagas&connect_timeout=60"
# Em dev local, use a mesma URL do DATABASE_URL. No Neon: pooled em DATABASE_URL e host direto (sem "-pooler") aqui.
# Opcional: se vazio, `pnpm run migrate:deploy` deriva a URL direta a partir de DATABASE_URL (Neon *-pooler*).
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:5432/jovem_aprendiz_vagas?schema=jovem_aprendiz_vagas&connect_timeout=60"
# PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1
# PRISMA_MIGRATE_DISABLE_LOCK_FALLBACK=1
# PRISMA_MIGRATE_STRICT_ADVISORY_LOCK=1
SITE_URL="https://slzcontent.com.br"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
AUTH_SECRET="troque-esta-chave-por-uma-segura"
# E-mail no login /admin. Se omitir LOGIN e SECRET, seed e db:seed-admin usam `lib/admin-bootstrap-credentials.ts`.
ADMIN_LOGIN_USER="joelsonmouraob@gmail.com"
# Omita esta linha no .env local para usar a senha de bootstrap no código (ou defina min. 8 caracteres e rode pnpm db:seed-admin).
# ADMIN_SECRET_KEY="sua-senha-forte"
SCHEDULED_JOBS_SPREADSHEET_PATH="C:\\caminho\\para\\sua\\planilha.xlsx"
SCHEDULED_JOBS_SHEET_NAME="Sheet1"
SCHEDULED_JOBS_LOG_DIR="C:\\caminho\\para\\logs"
GOOGLE_INDEXING_SERVICE_ACCOUNT_FILE="C:\\caminho\\fora-do-repo\\google-indexing-service-account.json"
GOOGLE_INDEXING_SERVICE_ACCOUNT_JSON=""
CRON_SECRET="defina-um-token-secreto-para-cron"
# Opcional: ativa a geracao de descricoes unicas na importacao de vagas quando o payload usar useAi=true.
ANTHROPIC_API_KEY=""
# Enriquecimento de localização (JobPosting) na importação — nunca expor no frontend.
GOOGLE_PLACES_API_KEY=""
# Opcional: padrão google_places
LOCATION_ENRICHMENT_PROVIDER="google_places"
# Backfill manual (npm run enrich:locations:backfill) — não roda automaticamente
# LOCATION_BACKFILL_CONCURRENCY=2
# LOCATION_BACKFILL_DELAY_MS=400
# LOCATION_BACKFILL_BATCH_SIZE=20
# Mantem eventos no GA sem gravar pageview no Neon. Use "true" apenas se precisar do painel interno de analytics.
INTERNAL_ANALYTICS_DB_ENABLED="false"
