generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Conexão direta (sem PgBouncer/pooler) para `prisma migrate`; evita P1002 em hosts tipo Neon `*-pooler.*`.
  directUrl = env("DATABASE_URL_DIRECT")
}

enum AdminRole {
  ADMIN
  EDITOR
}

enum EmploymentType {
  APPRENTICESHIP
  INTERNSHIP
  TEMPORARY
  PART_TIME
  FULL_TIME
  CONTRACTOR
  VOLUNTEER
  PER_DIEM
  OTHER
}

enum LocationType {
  ONSITE
  REMOTE
  HYBRID
}

enum HubType {
  STATE
  CITY
  COMPANY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  IMPORT
}

enum JobPublicationStatus {
  AGUARDANDO_AGENDAMENTO
  AGENDADA
  PUBLICANDO
  PUBLICADA
  INDEXANDO_GOOGLE
  OK
  ERRO
}

enum JobStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  EXPIRED
  ARCHIVED
  ERROR
}

enum InboxMessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum JobIndexingStatus {
  NOT_SENT
  QUEUED
  SENT
  ERROR
  SKIPPED
}

enum JobScheduleSource {
  PLANILHA
  ADMIN
  AUTOMATICO
  MANUAL
}

enum ImportQueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum LocationMatchStatus {
  MATCHED
  LOW_CONFIDENCE
  NOT_FOUND
  API_ERROR
}

model State {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(2)
  name      String   @unique
  slug      String   @unique
  seoTitle  String?
  seoIntro  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cities City[]
  companies Company[]
  jobs   Job[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String
  seoTitle  String?
  seoIntro  String?
  stateId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state State @relation(fields: [stateId], references: [id], onDelete: Cascade)
  companies Company[]
  jobs  Job[]

  @@unique([stateId, slug])
  @@unique([stateId, name])
}

model Company {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  websiteUrl     String?
  summary        String?  @db.Text
  descriptionHtml String? @db.Text
  socialImageUrl String?
  seoTitle       String?
  seoDescription String?
  isActive       Boolean  @default(true)
  featured       Boolean  @default(false)
  stateId        String
  cityId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  state State @relation(fields: [stateId], references: [id], onDelete: Restrict)
  city  City  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  jobs  Job[]

  @@index([isActive, updatedAt(sort: Desc)])
  @@index([stateId, cityId, isActive])
  @@index([featured, isActive])
}

model LocationEnrichmentCache {
  id                    String              @id @default(cuid())
  companyName           String
  companyNameNormalized String
  city                  String
  state                 String              @db.VarChar(2)
  provider              String
  providerPlaceId       String?
  streetAddress         String?
  postalCode            String?
  latitude              Float?
  longitude             Float?
  matchStatus           LocationMatchStatus
  matchConfidence       Float?
  rawQuery              String?
  lastFetchedAt         DateTime?
  lastValidatedAt       DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([companyNameNormalized, city, state])
  @@index([matchStatus])
}

model JobCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]
}

model Job {
  id                String         @id @default(cuid())
  externalId        String?        @unique
  title             String
  /** Cargo limpo para schema.org JobPosting.title (opcional; fallback em extractJobTitle(title)). */
  jobTitle          String?
  slug              String         @unique
  companyId         String?
  companyName       String
  companyLogoUrl    String?
  companyWebsiteUrl String?
  heroImageUrl      String?
  summary           String         @db.Text
  descriptionHtml   String         @db.Text
  responsibilities  Json?
  requirements      Json?
  benefits          Json?
  salaryMin         Int?
  salaryMax         Int?
  salaryDisplay     String?
  salaryCurrency    String         @default("BRL")
  categoryId        String?
  categoryName      String?
  employmentType    EmploymentType @default(APPRENTICESHIP)
  workHours         String?
  publishedAt       DateTime?
  updatedAt         DateTime       @updatedAt
  expiresAt         DateTime?
  validThrough      DateTime?
  applyUrl          String
  isActive          Boolean        @default(true)
  sourceName        String?
  sourceUrl         String?
  locationType      LocationType   @default(ONSITE)
  seoTitle          String?
  seoDescription    String?
  featured          Boolean        @default(false)
  stateId           String
  cityId            String
  createdAt         DateTime       @default(now())
  scheduledPublishAt DateTime?
  publicationStatus JobPublicationStatus @default(OK)
  googleIndexingStatus  String?  @db.VarChar(64)
  googleIndexingMessage String?  @db.Text
  googleIndexedAt       DateTime?
  publishedPublicUrl    String?
  status                JobStatus         @default(DRAFT)
  scheduledAt           DateTime?
  autoSubmitToIndexing  Boolean           @default(true)
  indexingStatus        JobIndexingStatus @default(NOT_SENT)
  indexingLastSubmittedAt DateTime?
  indexingError         String?           @db.Text
  scheduleSource        JobScheduleSource?
  scheduledImportRawValue String?
  importError           String?           @db.Text

  state State @relation(fields: [stateId], references: [id], onDelete: Restrict)
  city  City  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  category JobCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  indexingLogs IndexingLog[]

  @@index([categoryId, isActive])

  @@index([slug])
  @@index([isActive, publishedAt(sort: Desc)])
  @@index([stateId, cityId, isActive])
  @@index([companyId, isActive])
  @@index([publicationStatus, scheduledPublishAt])
  @@index([status, scheduledAt])
  @@index([status, isActive, publishedAt(sort: Desc)])
  @@index([indexingStatus, indexingLastSubmittedAt])
}

model IndexingLog {
  id          String   @id @default(cuid())
  jobId       String?
  url         String
  type        String
  status      String
  httpStatus  Int?
  response    Json?
  error       String?
  attempts    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model ImportQueue {
  id            String            @id @default(cuid())
  status        ImportQueueStatus @default(PENDING)
  payload       Json
  totalRows     Int               @default(0)
  processedRows Int               @default(0)
  importedCount Int               @default(0)
  updatedCount  Int               @default(0)
  errorCount    Int               @default(0)
  result        Json?
  errorMessage  String?           @db.Text
  createdById   String?
  createdByName String?
  createdByEmail String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, createdAt(sort: Desc)])
}

model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]
}

model BlogPost {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String   @db.Text
  contentHtml    String   @db.Text
  coverImageUrl  String?
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean  @default(true)
  publishedAt    DateTime
  updatedAt      DateTime @updatedAt
  categoryId     String

  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([slug])
  @@index([isPublished, publishedAt(sort: Desc)])
}

model SiteSetting {
  id           String   @id @default(cuid())
  key          String   @unique
  value        Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HubProfile {
  id             String   @id @default(cuid())
  type           HubType
  slug           String
  title          String?
  intro          String?
  contentHtml    String?
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  socialImageUrl String?
  noIndex        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([type, slug])
  @@index([type, updatedAt(sort: Desc)])
}

model MediaAsset {
  id           String   @id @default(cuid())
  originalName String
  fileName     String
  mimeType     String
  size         Int
  url          String   @unique
  altText      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AuditLog[]

  @@index([email, isActive])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId     String?
  actorName   String?
  actorEmail  String?
  actorRole   AdminRole?
  action      AuditAction
  entityType  String
  entityId    String?
  entityLabel String?
  summary     String?
  before      Json?
  after       Json?
  createdAt   DateTime    @default(now())

  actor AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  eventName   String
  path        String
  title       String?
  referrer    String?
  referrerHost String?
  source      String?
  medium      String?
  campaign    String?
  deviceType  String?
  browser     String?
  os          String?
  entityType  String?
  entityId    String?
  entitySlug  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([eventName, createdAt(sort: Desc)])
  @@index([path, createdAt(sort: Desc)])
  @@index([entityType, entitySlug, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@index([deviceType, createdAt(sort: Desc)])
}

model AdSettings {
  id            String   @id @default("singleton")
  globalEnabled Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id        String             @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String             @db.Text
  status    InboxMessageStatus @default(NEW)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status, createdAt(sort: Desc)])
}

model JobSubmission {
  id          String             @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String?
  jobTitle    String
  city        String
  description String             @db.Text
  applyUrl    String?
  message     String?            @db.Text
  status      InboxMessageStatus @default(NEW)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, createdAt(sort: Desc)])
}

model AdSlot {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  position        String   @db.VarChar(48)
  pageKey         String   @default("global") @db.VarChar(48)
  previewPath     String   @default("/") @db.VarChar(512)
  code            String   @default("") @db.Text
  adsenseSlotId   String?  @db.VarChar(32)
  isActive        Boolean  @default(true)
  maxPerPage      Int      @default(1)
  notes           String?  @db.Text
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pageKey, isActive])
  @@index([sortOrder])
}
